---
// LabVAR Landing Page
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>LabVAR — Your experiments deserve better than spreadsheets.</title>
  <meta name="description" content="Free, open-source, offline-first lab software. Design experiments, analyze data, and run your lab — all in one place." />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><text y='28' font-size='28'>🧪</text></svg>" />
</head>
<body>

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <div class="hero-badge">Open Source</div>
      <h1 class="hero-title">Lab<span class="accent">VAR</span></h1>
      <p class="hero-tagline">Your experiments deserve better than spreadsheets.</p>
      <p class="hero-subtitle">
        Free, open-source, offline-first. Design experiments, analyze data, and run your lab — all in one place.
      </p>
      <div class="hero-buttons">
        <a href="https://github.com/labvar/labvar/releases" class="btn btn-primary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 3a3 3 0 0 0-3 3v12a3 3 0 0 0 3 3 3 3 0 0 0 3-3 3 3 0 0 0-3-3H6a3 3 0 0 0-3 3 3 3 0 0 0 3 3 3 3 0 0 0 3-3V6a3 3 0 0 0-3-3 3 3 0 0 0-3 3 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 3 3 0 0 0-3-3z"></path></svg>
          Download for Mac
        </a>
        <a href="https://github.com/labvar/labvar/releases" class="btn btn-secondary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
          Download for Windows
        </a>
        <a href="https://github.com/labvar/labvar/releases" class="btn btn-secondary">
          <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
          Download for Linux
        </a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    <div class="container">
      <h2 class="section-heading">Everything your lab needs</h2>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
          </div>
          <h3 class="feature-title">Data &rarr; Figure + Stats</h3>
          <p class="feature-description">
            Import CSV. Drag columns onto plot encodings. Get publication-ready figures with guided statistical tests. Faster than R or Prism.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          </div>
          <h3 class="feature-title">Experiment Design</h3>
          <p class="feature-description">
            Structure your thinking: question, literature, hypothesis, null/alt, reviewer critique checklist. All linked in one record.
          </p>
        </div>

        <div class="feature-card">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
          </div>
          <h3 class="feature-title">Lab Management</h3>
          <p class="feature-description">
            Track reagent stocks with reorder alerts. Log cell culture maintenance. Never miss a passage again.
          </p>
        </div>

      </div>
    </div>
  </section>

  <!-- Integrity -->
  <section class="integrity">
    <div class="container">
      <div class="integrity-inner">
        <div class="integrity-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><polyline points="9 12 11 14 15 10"></polyline></svg>
        </div>
        <h2 class="integrity-heading">Built for integrity</h2>
        <p class="integrity-text">
          Every action you take is silently recorded in a tamper-evident, hash-chained log. Your data's provenance is captured from day one — no extra work required.
        </p>
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <p class="footer-text">
        Apache-2.0 &middot; <a href="https://github.com/labvar/labvar" class="footer-link">GitHub</a>
      </p>
    </div>
  </footer>

</body>
</html>

<style>
  /* ===== Reset & Base ===== */
  *, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen,
      Ubuntu, Cantarell, 'Helvetica Neue', Arial, sans-serif;
    background-color: #0f172a;
    color: #e2e8f0;
    line-height: 1.6;
  }

  .container {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ===== Hero ===== */
  .hero {
    padding: 6rem 0 5rem;
    text-align: center;
    background: radial-gradient(ellipse at 50% 0%, rgba(20, 184, 166, 0.08) 0%, transparent 60%);
  }

  .hero-badge {
    display: inline-block;
    padding: 0.3rem 1rem;
    margin-bottom: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #14b8a6;
    border: 1px solid rgba(20, 184, 166, 0.3);
    border-radius: 9999px;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #f1f5f9;
    line-height: 1.1;
  }

  .hero-title .accent {
    color: #14b8a6;
  }

  .hero-tagline {
    margin-top: 1rem;
    font-size: clamp(1.15rem, 3vw, 1.5rem);
    font-weight: 500;
    color: #cbd5e1;
  }

  .hero-subtitle {
    margin-top: 0.75rem;
    font-size: 1.05rem;
    color: #94a3b8;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 2.5rem;
  }

  /* ===== Buttons ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    cursor: pointer;
    border: 1px solid transparent;
  }

  .btn-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .btn-primary {
    background: #14b8a6;
    color: #022c22;
    border-color: #14b8a6;
  }

  .btn-primary:hover {
    background: #0d9488;
    border-color: #0d9488;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(20, 184, 166, 0.3);
  }

  .btn-secondary {
    background: transparent;
    color: #e2e8f0;
    border-color: #334155;
  }

  .btn-secondary:hover {
    border-color: #14b8a6;
    color: #14b8a6;
    transform: translateY(-1px);
    box-shadow: 0 4px 20px rgba(20, 184, 166, 0.1);
  }

  /* ===== Features ===== */
  .features {
    padding: 5rem 0;
  }

  .section-heading {
    text-align: center;
    font-size: 1.75rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 3rem;
    letter-spacing: -0.02em;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .feature-card {
    background: #1e293b;
    border: 1px solid #334155;
    border-radius: 0.75rem;
    padding: 2rem;
    transition: all 0.25s ease;
  }

  .feature-card:hover {
    border-color: rgba(20, 184, 166, 0.4);
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.3);
  }

  .feature-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(20, 184, 166, 0.1);
    border-radius: 0.5rem;
    margin-bottom: 1.25rem;
    color: #14b8a6;
  }

  .feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .feature-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .feature-description {
    font-size: 0.95rem;
    color: #94a3b8;
    line-height: 1.65;
  }

  /* ===== Integrity ===== */
  .integrity {
    padding: 4rem 0 5rem;
  }

  .integrity-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 2.5rem;
    background: linear-gradient(135deg, rgba(20, 184, 166, 0.06) 0%, rgba(20, 184, 166, 0.02) 100%);
    border: 1px solid rgba(20, 184, 166, 0.15);
    border-radius: 1rem;
  }

  .integrity-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    color: #14b8a6;
  }

  .integrity-icon svg {
    width: 36px;
    height: 36px;
  }

  .integrity-heading {
    font-size: 1.5rem;
    font-weight: 700;
    color: #f1f5f9;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .integrity-text {
    font-size: 1.05rem;
    color: #94a3b8;
    line-height: 1.7;
  }

  /* ===== Footer ===== */
  .footer {
    padding: 3rem 0;
    border-top: 1px solid #1e293b;
    text-align: center;
  }

  .footer-text {
    font-size: 0.9rem;
    color: #64748b;
  }

  .footer-link {
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: #14b8a6;
  }

  /* ===== Responsive ===== */
  @media (max-width: 768px) {
    .hero {
      padding: 4rem 0 3.5rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
    }

    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }

    .integrity-inner {
      padding: 2rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .hero-title {
      font-size: 2.5rem;
    }
  }
</style>
